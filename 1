    </div>

    <div class="nav-row">
        <button class="btn" onclick="changeItem(-1)">PREV</button>
        <span id="counter" style="font-weight: 800;">1 / 110</span>
        <button class="btn" onclick="changeItem(1)">NEXT</button>
    </div>

    <button id="recordBtn" class="btn btn-record" onclick="handleRecording()">🎙️ RECORD SAMPLE</button>
    
    <div class="soda-grid">
        <div class="soda-btn" onclick="logSoda('Normal', this)">Normal</div>
        <div class="soda-btn" onclick="logSoda('Substitution', this)">Substitution</div>
        <div class="soda-btn" onclick="logSoda('Omission', this)">Omission</div>
