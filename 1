<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Complete Hindi Articulation Battery</title>
    <style>
        :root { --primary: #0284c7; --bg: #f8fafc; --text: #0f172a; }
        body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 10px; display: flex; flex-direction: column; align-items: center; }
        .container { width: 100%; max-width: 450px; background: #fff; padding: 20px; border-radius: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); box-sizing: border-box; }
        .stimulus-box { width: 100%; height: 300px; background: #f1f5f9; border-radius: 18px; display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 15px; overflow: hidden; }
        .stimulus-image { max-width: 90%; max-height: 70%; object-fit: contain; }
        .target-word { font-size: 2.5rem; font-weight: 800; margin-top: 10px; color: var(--primary); }
        .nav-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .btn { padding: 12px 18px; border-radius: 12px; border: none; font-weight: 700; cursor: pointer; }
        .btn-record { background: #ef4444; color: white; width: 100%; margin-bottom: 15px; font-size: 1rem; }
        .recording { background: #991b1b; animation: pulse 1.5s infinite; }
        .soda-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; background: #f1f5f9; padding: 12px; border-radius: 16px; }
        .soda-btn { background: white; border: 1px solid #cbd5e1; padding: 10px; border-radius: 8px; font-size: 0.85rem; text-align: center; cursor: pointer; }
        .soda-btn.selected { background: var(--primary); color: white; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.7; } }
    </style>
</head>
